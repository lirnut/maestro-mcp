# Maestro MCP environment variables
# Copy this file:  cp .env.example .env

# SHA-256 hash of your authorization PIN (required for OAuth consent gate)
# Generate: python -c "import hashlib; pin = input('PIN: '); print(hashlib.sha256(pin.encode()).hexdigest())"
MAESTRO_AUTHORIZE_PIN_HASH=""

# SSH command timeout in seconds (default: 300)
SSH_TIMEOUT=300

# Public URL where Maestro is reachable (required for HTTP transport with OAuth)
# For local/stdio usage, leave as default
MAESTRO_ISSUER_URL=https://your-domain.example.com

# Bearer token for /transfer/push and /transfer/pull HTTP endpoints.
# These allow sandboxed agents to transfer files without MCP, keeping
# file bytes off the LLM context window.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
MAESTRO_TRANSFER_TOKEN=""

# Comma-separated list of allowed base directories for /transfer/push and
# /transfer/pull. Paths outside these directories are rejected (HTTP 403).
# Default: ~/ (the server user's home directory).
MAESTRO_TRANSFER_ALLOWED_DIRS="~/"

# Comma-separated list of OAuth client_ids that bypass the PIN gate
# (auto-approved). Use for trusted clients like Claude.ai where the user
# is already authenticated in their provider account.
# Find the client_id in the audit log after the client registers.
MAESTRO_TRUSTED_CLIENT_IDS=""

# Default working directory for agent orchestra tools
# MAESTRO_DEFAULT_REPO=~/workspace
